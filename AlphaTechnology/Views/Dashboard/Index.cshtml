@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Dashboard";
}

<!-- Page Header -->
<div class="page-header">
  <div>
    <h1 class="page-title">Dashboard</h1>
    <p class="page-subtitle">Selamat datang kembali, Admin! Ini ringkasan operasional Alpha Technology.</p>
  </div>
  <div class="page-header-actions">
    <span class="today-badge"><i class='bx bx-calendar'></i> April 2026</span>
    <button class="btn-primary-sm" onclick="exportReport()">
      <i class='bx bx-download'></i> Export Laporan
    </button>
  </div>
</div>

<!-- ========== STAT CARDS ========== -->
<div class="stat-grid">
  <div class="stat-card" data-delay="0">
    <div class="stat-card-inner">
      <div class="stat-info">
        <p class="stat-label">Total Proyek</p>
        <h2 class="stat-value" data-target="47">0</h2>
        <div class="stat-change positive"><i class='bx bx-trending-up'></i><span>+12% dari bulan lalu</span></div>
      </div>
      <div class="stat-icon bg-primary"><i class='bx bx-folder-open'></i></div>
    </div>
    <div class="stat-sparkline" id="spark-projects"></div>
  </div>
  <div class="stat-card" data-delay="100">
    <div class="stat-card-inner">
      <div class="stat-info">
        <p class="stat-label">Klien Aktif</p>
        <h2 class="stat-value" data-target="23">0</h2>
        <div class="stat-change positive"><i class='bx bx-trending-up'></i><span>+8% dari bulan lalu</span></div>
      </div>
      <div class="stat-icon bg-success"><i class='bx bxs-user-detail'></i></div>
    </div>
    <div class="stat-sparkline" id="spark-clients"></div>
  </div>
  <div class="stat-card" data-delay="200">
    <div class="stat-card-inner">
      <div class="stat-info">
        <p class="stat-label">Revenue (Rp)</p>
        <h2 class="stat-value revenue-val">285 Jt</h2>
        <div class="stat-change positive"><i class='bx bx-trending-up'></i><span>+18% dari bulan lalu</span></div>
      </div>
      <div class="stat-icon bg-warning"><i class='bx bx-money-withdraw'></i></div>
    </div>
    <div class="stat-sparkline" id="spark-revenue"></div>
  </div>
  <div class="stat-card" data-delay="300">
    <div class="stat-card-inner">
      <div class="stat-info">
        <p class="stat-label">Tingkat Selesai</p>
        <h2 class="stat-value">94%</h2>
        <div class="stat-change positive"><i class='bx bx-trending-up'></i><span>+3% dari bulan lalu</span></div>
      </div>
      <div class="stat-icon bg-info"><i class='bx bx-check-shield'></i></div>
    </div>
    <div class="stat-sparkline" id="spark-rate"></div>
  </div>
</div>

<!-- ========== CHARTS ROW ========== -->
<div class="charts-row">
  <div class="card chart-card large">
    <div class="card-header">
      <div>
        <h5 class="card-title">Revenue Overview</h5>
        <p class="card-subtitle">Pendapatan bulanan tahun 2026</p>
      </div>
      <div class="card-actions">
        <div class="tab-pills">
          <button class="tab-pill active" onclick="switchRevChart('monthly', this)">Bulanan</button>
          <button class="tab-pill" onclick="switchRevChart('quarterly', this)">Kuartalan</button>
        </div>
      </div>
    </div>
    <div id="revenueChart"></div>
  </div>
  <div class="card chart-card small">
    <div class="card-header">
      <div>
        <h5 class="card-title">Proyek per Layanan</h5>
        <p class="card-subtitle">Distribusi layanan aktif</p>
      </div>
    </div>
    <div id="serviceChart"></div>
    <div class="legend-list">
      <div class="legend-item"><span class="legend-dot" style="background:#556ee6"></span><span>Custom Web App</span><strong>42%</strong></div>
      <div class="legend-item"><span class="legend-dot" style="background:#34c38f"></span><span>Sistem Internal</span><strong>28%</strong></div>
      <div class="legend-item"><span class="legend-dot" style="background:#f1b44c"></span><span>API Integration</span><strong>18%</strong></div>
      <div class="legend-item"><span class="legend-dot" style="background:#f46a6a"></span><span>Data & Reporting</span><strong>12%</strong></div>
    </div>
  </div>
</div>

<!-- ========== TABLE + ACTIVITY ROW ========== -->
<div class="table-activity-row">
  <div class="card table-card">
    <div class="card-header">
      <div>
        <h5 class="card-title">Proyek Terbaru</h5>
        <p class="card-subtitle">Daftar proyek yang sedang berjalan</p>
      </div>
      <a asp-controller="Projects" asp-action="Index" class="card-link">Lihat Semua <i class='bx bx-arrow-right'></i></a>
    </div>
    <div class="table-wrapper">
      <table class="data-table">
        <thead>
          <tr><th>#</th><th>Nama Proyek</th><th>Klien</th><th>Layanan</th><th>Deadline</th><th>Status</th><th>Progress</th></tr>
        </thead>
        <tbody>
          <tr>
            <td><span class="row-num">001</span></td>
            <td><div class="project-name"><div class="project-icon bg-primary-soft"><i class='bx bx-code-alt'></i></div>HR Management System</div></td>
            <td>PT Maju Bersama</td>
            <td><span class="tag tag-primary">Sistem Internal</span></td>
            <td>30 Apr 2026</td>
            <td><span class="status-badge in-progress">In Progress</span></td>
            <td><div class="progress-cell"><div class="mini-progress"><div class="mini-bar" style="width:75%;background:#556ee6"></div></div><span>75%</span></div></td>
          </tr>
          <tr>
            <td><span class="row-num">002</span></td>
            <td><div class="project-name"><div class="project-icon bg-success-soft"><i class='bx bx-cart'></i></div>E-Commerce Portal</div></td>
            <td>Toko Berkah Online</td>
            <td><span class="tag tag-success">Custom Web App</span></td>
            <td>15 Mei 2026</td>
            <td><span class="status-badge in-progress">In Progress</span></td>
            <td><div class="progress-cell"><div class="mini-progress"><div class="mini-bar" style="width:58%;background:#34c38f"></div></div><span>58%</span></div></td>
          </tr>
          <tr>
            <td><span class="row-num">003</span></td>
            <td><div class="project-name"><div class="project-icon bg-warning-soft"><i class='bx bx-data'></i></div>Inventory & Stock System</div></td>
            <td>CV Logistik Nusantara</td>
            <td><span class="tag tag-warning">Sistem Internal</span></td>
            <td>10 Apr 2026</td>
            <td><span class="status-badge completed">Completed</span></td>
            <td><div class="progress-cell"><div class="mini-progress"><div class="mini-bar" style="width:100%;background:#34c38f"></div></div><span>100%</span></div></td>
          </tr>
          <tr>
            <td><span class="row-num">004</span></td>
            <td><div class="project-name"><div class="project-icon bg-info-soft"><i class='bx bx-transfer'></i></div>Payment Gateway API</div></td>
            <td>Startup FinUp</td>
            <td><span class="tag tag-info">API Integration</span></td>
            <td>20 Mei 2026</td>
            <td><span class="status-badge in-progress">In Progress</span></td>
            <td><div class="progress-cell"><div class="mini-progress"><div class="mini-bar" style="width:40%;background:#50a5f1"></div></div><span>40%</span></div></td>
          </tr>
          <tr>
            <td><span class="row-num">005</span></td>
            <td><div class="project-name"><div class="project-icon bg-danger-soft"><i class='bx bx-bar-chart-alt'></i></div>Sales Analytics Dashboard</div></td>
            <td>PT Sukses Mandiri</td>
            <td><span class="tag tag-danger">Data & Reporting</span></td>
            <td>05 Jun 2026</td>
            <td><span class="status-badge planning">Planning</span></td>
            <td><div class="progress-cell"><div class="mini-progress"><div class="mini-bar" style="width:15%;background:#f46a6a"></div></div><span>15%</span></div></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <div class="side-col">
    <div class="card tech-card">
      <div class="card-header">
        <h5 class="card-title">Tech Stack</h5>
        <p class="card-subtitle">Arsitektur yang kami gunakan</p>
      </div>
      <div class="tech-list">
        <div class="tech-item">
          <div class="tech-icon dotnet"><i class='bx bx-code-curly'></i></div>
          <div class="tech-info"><p class="tech-name">.NET Core 8</p><p class="tech-desc">Backend Language</p></div>
          <span class="tech-badge primary">Enterprise</span>
        </div>
        <div class="tech-item">
          <div class="tech-icon sql"><i class='bx bx-server'></i></div>
          <div class="tech-info"><p class="tech-name">MS SQL Server</p><p class="tech-desc">Database Engine</p></div>
          <span class="tech-badge success">Robust</span>
        </div>
        <div class="tech-item">
          <div class="tech-icon arch"><i class='bx bx-layer'></i></div>
          <div class="tech-info"><p class="tech-name">Monolithic</p><p class="tech-desc">Arsitektur Utama</p></div>
          <span class="tech-badge info">Scalable</span>
        </div>
      </div>
    </div>

    <div class="card activity-card">
      <div class="card-header">
        <h5 class="card-title">Aktivitas Terbaru</h5>
        <a href="#" class="card-link">Semua <i class='bx bx-arrow-right'></i></a>
      </div>
      <div class="timeline">
        <div class="timeline-item">
          <div class="timeline-dot bg-primary"></div>
          <div class="timeline-content">
            <p class="tl-text">Proyek <strong>HR System</strong> mencapai milestone deployment staging</p>
            <span class="tl-time"><i class='bx bx-time-five'></i> 2 jam lalu</span>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot bg-success"></div>
          <div class="timeline-content">
            <p class="tl-text">Invoice <strong>#INV-047</strong> senilai Rp 45jt berhasil dibayar</p>
            <span class="tl-time"><i class='bx bx-time-five'></i> 5 jam lalu</span>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot bg-warning"></div>
          <div class="timeline-content">
            <p class="tl-text">Meeting requirement gathering klien <strong>FinUp</strong> selesai</p>
            <span class="tl-time"><i class='bx bx-time-five'></i> Kemarin, 14:30</span>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot bg-info"></div>
          <div class="timeline-content">
            <p class="tl-text">Deploy <strong>Inventory System</strong> ke production berhasil</p>
            <span class="tl-time"><i class='bx bx-time-five'></i> 2 hari lalu</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ========== BOTTOM ROW ========== -->
<div class="bottom-row">
  <div class="card segment-card">
    <div class="card-header">
      <div><h5 class="card-title">Segmen Klien</h5><p class="card-subtitle">Berdasarkan kategori target pasar</p></div>
    </div>
    <div id="segmentChart"></div>
    <div class="segment-list">
      <div class="segment-item"><div class="seg-label"><span class="legend-dot" style="background:#556ee6"></span>UMKM</div><div class="seg-bar-wrap"><div class="seg-bar" style="width:45%;background:#556ee6"></div></div><span class="seg-pct">45%</span></div>
      <div class="segment-item"><div class="seg-label"><span class="legend-dot" style="background:#34c38f"></span>Startup</div><div class="seg-bar-wrap"><div class="seg-bar" style="width:30%;background:#34c38f"></div></div><span class="seg-pct">30%</span></div>
      <div class="segment-item"><div class="seg-label"><span class="legend-dot" style="background:#f1b44c"></span>Menengah</div><div class="seg-bar-wrap"><div class="seg-bar" style="width:18%;background:#f1b44c"></div></div><span class="seg-pct">18%</span></div>
      <div class="segment-item"><div class="seg-label"><span class="legend-dot" style="background:#f46a6a"></span>Konvensional</div><div class="seg-bar-wrap"><div class="seg-bar" style="width:7%;background:#f46a6a"></div></div><span class="seg-pct">7%</span></div>
    </div>
  </div>

  <div class="card radial-card">
    <div class="card-header">
      <div><h5 class="card-title">Status Proyek</h5><p class="card-subtitle">Distribusi status saat ini</p></div>
    </div>
    <div id="radialChart"></div>
  </div>

  <div class="card vision-card">
    <div class="vision-bg"></div>
    <div class="vision-content">
      <div class="vision-icon"><i class='bx bx-rocket'></i></div>
      <h5 class="vision-title">Visi 2030</h5>
      <p class="vision-text">Menjadi mitra transformasi digital terdepan dengan <strong>100+ proyek</strong> dan ratusan klien terpercaya di berbagai sektor bisnis Indonesia.</p>
      <div class="target-stats">
        <div class="target-stat"><strong>100+</strong><span>Proyek Target</span></div>
        <div class="target-divider"></div>
        <div class="target-stat"><strong>2030</strong><span>Target Tahun</span></div>
        <div class="target-divider"></div>
        <div class="target-stat"><strong>47%</strong><span>Tercapai</span></div>
      </div>
    </div>
  </div>
</div>

@section Scripts {
  <script src="~/js/dashboard/dashboard.js"></script>
}
