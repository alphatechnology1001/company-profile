@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Daftar Proyek";
}

<div class="page-header">
  <div>
    <h1 class="page-title">Daftar Proyek</h1>
    <p class="page-subtitle">Pantau semua proyek aktif dan riwayat pengembangan Alpha Technology</p>
  </div>
  <div class="page-header-actions">
    <a asp-controller="Projects" asp-action="Overview" class="btn btn-outline"><i class='bx bx-show'></i> Overview</a>
    <a asp-controller="Projects" asp-action="Create" class="btn btn-primary"><i class='bx bx-plus'></i> Proyek Baru</a>
  </div>
</div>

<div class="card">
  <div class="proj-stat-bar">
    <div class="proj-stat-cell">
      <div class="proj-stat-num" style="color:var(--primary)">12</div>
      <div class="proj-stat-lbl">Proyek Aktif</div>
    </div>
    <div class="proj-stat-cell">
      <div class="proj-stat-num" style="color:var(--success)">35</div>
      <div class="proj-stat-lbl">Selesai</div>
    </div>
    <div class="proj-stat-cell">
      <div class="proj-stat-num" style="color:var(--warning)">4</div>
      <div class="proj-stat-lbl">Dalam Review</div>
    </div>
    <div class="proj-stat-cell">
      <div class="proj-stat-num" style="color:var(--danger)">2</div>
      <div class="proj-stat-lbl">Terlambat</div>
    </div>
  </div>

  <div class="proj-list-toolbar">
    <div class="proj-search">
      <i class='bx bx-search' style="color:var(--text-muted)"></i>
      <input type="text" placeholder="Cari proyek..." id="projSearch" oninput="filterProjects()" />
    </div>
    <select class="filter-select" id="projStatus" onchange="filterProjects()">
      <option value="">Semua Status</option>
      <option value="in-progress">In Progress</option>
      <option value="completed">Selesai</option>
      <option value="planning">Planning</option>
    </select>
    <select class="filter-select" id="projService" onchange="filterProjects()">
      <option value="">Semua Layanan</option>
      <option value="Custom Web App">Custom Web App</option>
      <option value="Sistem Internal">Sistem Internal</option>
      <option value="API Integration">API Integration</option>
      <option value="Data &amp; Reporting">Data &amp; Reporting</option>
    </select>
    <div style="margin-left:auto;display:flex;gap:8px">
      <button class="btn btn-outline btn-sm btn-icon" title="List View"><i class='bx bx-list-ul'></i></button>
      <button class="btn btn-primary btn-sm btn-icon" title="Grid View"><i class='bx bx-grid-alt'></i></button>
    </div>
  </div>

  <div class="proj-list-wrapper" id="projList"></div>
</div>

@section Scripts {
<script>
  const overviewUrl = '@Url.Action("Overview", "Projects")';
  const createUrl   = '@Url.Action("Create",   "Projects")';

  const PROJECTS = [
    {
      icon:'bx bx-code-alt', iconBg:'bg-primary-soft',
      name:'HR Management System', client:'PT Maju Bersama',
      desc:'Sistem manajemen SDM lengkap mencakup modul karyawan, absensi, penggajian, dan pelaporan.',
      service:'Sistem Internal', status:'in-progress', progress:75,
      deadline:'30 Apr 2026', team:['#556ee6','#34c38f','#f1b44c'], extra:1,
      tagClass:'tag-primary', tagLabel:'Sistem Internal',
    },
    {
      icon:'bx bx-cart', iconBg:'bg-success-soft',
      name:'E-Commerce Portal', client:'Toko Berkah Online',
      desc:'Platform belanja online dengan fitur produk, cart, checkout, dan dashboard admin.',
      service:'Custom Web App', status:'in-progress', progress:58,
      deadline:'15 Mei 2026', team:['#556ee6','#8B5CF6'], extra:0,
      tagClass:'tag-success', tagLabel:'Custom Web App',
    },
    {
      icon:'bx bx-data', iconBg:'bg-warning-soft',
      name:'Inventory & Stock System', client:'CV Logistik Nusantara',
      desc:'Sistem manajemen gudang dan stok barang dengan laporan real-time dan notifikasi otomatis.',
      service:'Sistem Internal', status:'completed', progress:100,
      deadline:'10 Apr 2026', team:['#f1b44c','#34c38f'], extra:0,
      tagClass:'tag-warning', tagLabel:'Sistem Internal',
    },
    {
      icon:'bx bx-transfer', iconBg:'bg-info-soft',
      name:'Payment Gateway API', client:'Startup FinUp',
      desc:'Integrasi API payment gateway multi-provider: Midtrans, Xendit, dan DOKU.',
      service:'API Integration', status:'in-progress', progress:40,
      deadline:'20 Mei 2026', team:['#50a5f1','#f46a6a'], extra:0,
      tagClass:'tag-info', tagLabel:'API Integration',
    },
    {
      icon:'bx bx-bar-chart-alt', iconBg:'bg-danger-soft',
      name:'Sales Analytics Dashboard', client:'PT Sukses Mandiri',
      desc:'Dashboard analitik penjualan dengan visualisasi data real-time dan export laporan otomatis.',
      service:'Data & Reporting', status:'planning', progress:15,
      deadline:'05 Jun 2026', team:['#f46a6a'], extra:0,
      tagClass:'tag-danger', tagLabel:'Data & Reporting',
    },
    {
      icon:'bx bx-spreadsheet', iconBg:'bg-primary-soft',
      name:'Approval Workflow System', client:'Koperasi Sejahtera',
      desc:'Sistem persetujuan dokumen digital multi-level untuk pengajuan kredit dan pembiayaan.',
      service:'Sistem Internal', status:'planning', progress:10,
      deadline:'25 Jun 2026', team:['#556ee6','#8B5CF6'], extra:1,
      tagClass:'tag-primary', tagLabel:'Sistem Internal',
    },
  ];

  const STATUS_BADGE = {
    'in-progress': '<span class="status-badge in-progress">In Progress</span>',
    'completed':   '<span class="status-badge completed">Selesai</span>',
    'planning':    '<span class="status-badge planning">Planning</span>',
  };

  function renderProjects(data) {
    const container = document.getElementById('projList');
    container.innerHTML = data.map(p => `
      <div class="proj-list-item">
        <div class="proj-item-icon ${p.iconBg}">
          <i class='${p.icon}' style="font-size:24px"></i>
        </div>
        <div style="min-width:0">
          <div class="proj-item-name">${p.name}</div>
          <div class="proj-item-desc">${p.desc}</div>
          <div class="proj-item-tags">
            <span class="tag ${p.tagClass}">${p.tagLabel}</span>
            <span style="font-size:12px;color:var(--text-muted)">Klien: <strong>${p.client}</strong></span>
          </div>
        </div>
        <div class="proj-team-stack">
          ${p.team.map(c => `<div class="proj-team-avatar" style="background:${c}">${c.replace('#','').substring(0,2).toUpperCase()}</div>`).join('')}
          ${p.extra > 0 ? `<div class="proj-team-avatar proj-team-more">+${p.extra}</div>` : ''}
        </div>
        <div class="proj-deadline">
          <div class="proj-deadline-date">${p.deadline}</div>
          <div class="proj-deadline-label">Deadline</div>
        </div>
        <div class="proj-progress-col">
          <div class="proj-progress-label">
            <span>Progress</span><span>${p.progress}%</span>
          </div>
          <div class="proj-progress-bar">
            <div class="proj-progress-fill" style="width:${p.progress}%;background:${p.status==='completed'?'var(--success)':p.status==='planning'?'var(--warning)':'var(--primary)'}"></div>
          </div>
        </div>
        <div>${STATUS_BADGE[p.status]}</div>
        <div style="display:flex;gap:6px;flex-shrink:0">
          <a href="${overviewUrl}" class="btn btn-outline btn-sm" title="Detail"><i class='bx bx-show'></i></a>
          <a href="${createUrl}"   class="btn btn-outline btn-sm" title="Edit"><i class='bx bx-edit'></i></a>
        </div>
      </div>
    `).join('');
  }

  function filterProjects() {
    const q  = document.getElementById('projSearch').value.toLowerCase();
    const st = document.getElementById('projStatus').value;
    const sv = document.getElementById('projService').value;
    const filtered = PROJECTS.filter(p =>
      (!q  || p.name.toLowerCase().includes(q) || p.client.toLowerCase().includes(q)) &&
      (!st || p.status  === st) &&
      (!sv || p.service === sv)
    );
    renderProjects(filtered);
  }

  renderProjects(PROJECTS);
</script>
}
