@{
    var activePage = ViewData["ActivePage"] as string ?? "";
    var breadcrumb = ViewData["Breadcrumb"] as string ?? "Dashboard";
}
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@(ViewData["Title"] ?? "Dashboard") | Alpha Technology</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

  <link rel="stylesheet" href="~/css/dashboard/style.css" />
  <link rel="stylesheet" href="~/css/dashboard/pages.css" />

  @RenderSection("Head", required: false)
</head>
<body>

  <!-- ========== SIDEBAR ========== -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-brand">
      <div class="brand-logo"><span class="brand-icon">α</span></div>
      <div class="brand-text">
        <span class="brand-name">Alpha</span>
        <span class="brand-sub">Technology</span>
      </div>
      <button class="sidebar-toggle-btn" id="sidebarToggle"><i class='bx bx-menu'></i></button>
    </div>

    <nav class="sidebar-nav">
      <div class="nav-label">MENU UTAMA</div>

      <a asp-controller="Dashboard" asp-action="Index" class="nav-item @(activePage == "dashboard" ? "active" : "")">
        <i class='bx bxs-dashboard'></i><span>Dashboard</span>
      </a>
      <a asp-controller="Home" asp-action="Index" class="nav-item @(activePage == "home" ? "active" : "")">
        <i class='bx bx-home'></i><span>Beranda</span>
      </a>
      <a asp-controller="Calendar" asp-action="Index" class="nav-item @(activePage == "calendar" ? "active" : "")">
        <i class='bx bx-calendar'></i><span>Kalender</span>
      </a>
      <a asp-controller="Projects" asp-action="Index" class="nav-item @(activePage == "projects" ? "active" : "")">
        <i class='bx bx-folder-open'></i><span>Proyek</span><span class="nav-badge">12</span>
      </a>
      <a asp-controller="Tasks" asp-action="Kanban" class="nav-item @(activePage == "tasks" ? "active" : "")">
        <i class='bx bx-task'></i><span>Tasks</span>
      </a>

      <div class="nav-label">KEUANGAN</div>

      <a asp-controller="Invoices" asp-action="Index" class="nav-item @(activePage == "invoices" ? "active" : "")">
        <i class='bx bx-receipt'></i><span>Invoice</span>
      </a>
      <a href="#" class="nav-item"><i class='bx bx-line-chart'></i><span>Revenue</span></a>

      <div class="nav-label">TEKNOLOGI</div>

      <a href="#" class="nav-item"><i class='bx bx-code-block'></i><span>Tech Stack</span></a>
      <a href="#" class="nav-item"><i class='bx bx-group'></i><span>Tim Kami</span></a>

      <div class="nav-label">SISTEM</div>

      <a href="#" class="nav-item"><i class='bx bx-cog'></i><span>Pengaturan</span></a>
      <a href="#" class="nav-item"><i class='bx bx-support'></i><span>Bantuan</span></a>
    </nav>

    <div class="sidebar-footer">
      <div class="user-avatar-sm">AT</div>
      <div class="user-info-sm">
        <span class="user-name-sm">Admin</span>
        <span class="user-role-sm">Super Admin</span>
      </div>
      <i class='bx bx-log-out logout-icon'></i>
    </div>
  </aside>

  <!-- ========== MAIN WRAPPER ========== -->
  <div class="main-wrapper" id="mainWrapper">

    <!-- ========== TOPBAR ========== -->
    <header class="topbar">
      <div class="topbar-left">
        <button class="topbar-toggle" id="topbarToggle"><i class='bx bx-menu'></i></button>
        <div class="breadcrumb">
          <span class="breadcrumb-item">Alpha Technology</span>
          <i class='bx bx-chevron-right breadcrumb-sep'></i>
          <span class="breadcrumb-item active">@breadcrumb</span>
        </div>
      </div>
      <div class="topbar-right">
        <div class="topbar-search">
          <i class='bx bx-search'></i>
          <input type="text" placeholder="Cari proyek, klien..." />
        </div>
        <div class="topbar-icon-btn" id="notifBtn">
          <i class='bx bx-bell'></i>
          <span class="notif-dot"></span>
          <div class="dropdown-panel notif-panel" id="notifPanel">
            <div class="dp-header"><h6>Notifikasi</h6><span class="badge-count">4</span></div>
            <div class="notif-list">
              <div class="notif-item">
                <div class="notif-icon bg-primary-soft"><i class='bx bx-folder'></i></div>
                <div class="notif-text"><p>Proyek HR System PT Maju — <strong>selesai review</strong></p><small>5 menit lalu</small></div>
              </div>
              <div class="notif-item">
                <div class="notif-icon bg-success-soft"><i class='bx bx-check-circle'></i></div>
                <div class="notif-text"><p>Invoice #INV-2026-047 sudah <strong>dibayar</strong></p><small>1 jam lalu</small></div>
              </div>
              <div class="notif-item">
                <div class="notif-icon bg-warning-soft"><i class='bx bx-time'></i></div>
                <div class="notif-text"><p>Deadline Inventory System — <strong>3 hari lagi</strong></p><small>2 jam lalu</small></div>
              </div>
              <div class="notif-item">
                <div class="notif-icon bg-info-soft"><i class='bx bx-message'></i></div>
                <div class="notif-text"><p>Pesan baru dari klien <strong>Toko Berkah</strong></p><small>Kemarin</small></div>
              </div>
            </div>
            <div class="dp-footer"><a href="#">Lihat semua notifikasi</a></div>
          </div>
        </div>
        <div class="topbar-user" id="userBtn">
          <div class="user-avatar">AT</div>
          <div class="user-info">
            <span class="user-name">Admin</span>
            <span class="user-role">Super Admin</span>
          </div>
          <i class='bx bx-chevron-down'></i>
          <div class="dropdown-panel user-panel" id="userPanel">
            <div class="dp-user-header">
              <div class="user-avatar lg">AT</div>
              <div><p class="dp-user-name">Administrator</p><small>admin@alphatech.id</small></div>
            </div>
            <div class="dp-links">
              <a href="#"><i class='bx bx-user'></i> Profil Saya</a>
              <a href="#"><i class='bx bx-cog'></i> Pengaturan</a>
              <a href="#"><i class='bx bx-lock'></i> Kunci Layar</a>
            </div>
            <div class="dp-footer">
              <a asp-controller="Home" asp-action="Index" class="logout-link"><i class='bx bx-power-off'></i> Keluar</a>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- ========== PAGE CONTENT ========== -->
    <main class="page-content">
      @RenderBody()
    </main>

    <footer class="page-footer">
      <p>© 2026 <strong>Alpha Technology</strong> — Building Scalable Digital Solutions</p>
      <p>Powered by <strong>.NET Core 8</strong> &amp; <strong>MS SQL Server</strong></p>
    </footer>

  </div>

  @RenderSection("Modals", required: false)

  <script>
    (function () {
      const sidebar     = document.getElementById('sidebar');
      const mainWrapper = document.getElementById('mainWrapper');
      const toggle      = document.getElementById('topbarToggle');
      const sideToggle  = document.getElementById('sidebarToggle');

      function collapseToggle() {
        if (window.innerWidth <= 768) {
          sidebar.classList.toggle('mobile-show');
        } else {
          sidebar.classList.toggle('collapsed');
          mainWrapper.classList.toggle('collapsed');
        }
      }
      if (toggle)     toggle.addEventListener('click', collapseToggle);
      if (sideToggle) sideToggle.addEventListener('click', collapseToggle);

      const notifBtn   = document.getElementById('notifBtn');
      const notifPanel = document.getElementById('notifPanel');
      const userBtn    = document.getElementById('userBtn');
      const userPanel  = document.getElementById('userPanel');

      function closeAll() {
        [notifPanel, userPanel].forEach(p => p && p.classList.remove('show'));
      }
      if (notifBtn) notifBtn.addEventListener('click', e => { e.stopPropagation(); notifPanel.classList.toggle('show'); userPanel.classList.remove('show'); });
      if (userBtn)  userBtn.addEventListener('click',  e => { e.stopPropagation(); userPanel.classList.toggle('show'); notifPanel.classList.remove('show'); });
      document.addEventListener('click', closeAll);
    })();
  </script>

  @RenderSection("Scripts", required: false)
</body>
</html>
