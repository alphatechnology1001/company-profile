<!DOCTYPE html>
<html class="no-js" lang="id">
<head>
  <meta charset="utf-8" />
  <meta http-equiv="x-ua-compatible" content="ie=edge" />
  <title>@(ViewData["Title"] ?? "Alpha Tech - Building Scalable Digital Solutions")</title>
  <meta name="description" content="Alpha Technology - Perusahaan IT penyedia Custom Web Application dan Sistem Internal berbasis .NET" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <link rel="stylesheet" href="~/css/landing/bootstrap-5.0.0-alpha-2.min.css" />
  <link rel="stylesheet" href="~/css/landing/LineIcons.2.0.css" />
  <link rel="stylesheet" href="~/css/landing/animate.css" />
  <link rel="stylesheet" href="~/css/landing/lindy-uikit.css" />
</head>
<body>

  <div class="preloader">
    <div class="loader">
      <div class="spinner">
        <div class="spinner-container">
          <div class="spinner-rotator">
            <div class="spinner-left"><div class="spinner-circle"></div></div>
            <div class="spinner-right"><div class="spinner-circle"></div></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  @RenderBody()

  <a href="#" class="scroll-top"><i class="lni lni-chevron-up"></i></a>

  <script src="~/js/landing/bootstrap.5.0.0.alpha-2-min.js"></script>
  <script src="~/js/landing/count-up.min.js"></script>
  <script src="~/js/landing/wow.min.js"></script>
  <script src="~/js/landing/main.js"></script>

  @RenderSection("Scripts", required: false)
</body>
</html>
