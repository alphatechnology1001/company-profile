@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Daftar Invoice";
}

<div class="page-header">
  <div>
    <h1 class="page-title">Daftar Invoice</h1>
    <p class="page-subtitle">Kelola semua invoice dan tagihan klien Alpha Technology</p>
  </div>
  <div class="page-header-actions">
    <a asp-controller="Invoices" asp-action="Detail" class="btn btn-primary">
      <i class='bx bx-plus'></i> Invoice Baru
    </a>
  </div>
</div>

<div class="card">
  <div class="inv-stat-cards">
    <div class="inv-stat-cell"><div class="inv-stat-label">Total Invoice</div><div class="inv-stat-value">47</div><div class="inv-stat-sub">Semua invoice 2026</div></div>
    <div class="inv-stat-cell"><div class="inv-stat-label" style="color:var(--success)">Terbayar</div><div class="inv-stat-value" style="color:var(--success)">Rp 245jt</div><div class="inv-stat-sub">32 invoice lunas</div></div>
    <div class="inv-stat-cell"><div class="inv-stat-label" style="color:var(--warning)">Tertunda</div><div class="inv-stat-value" style="color:var(--warning)">Rp 68jt</div><div class="inv-stat-sub">11 invoice pending</div></div>
    <div class="inv-stat-cell"><div class="inv-stat-label" style="color:var(--danger)">Jatuh Tempo</div><div class="inv-stat-value" style="color:var(--danger)">Rp 22jt</div><div class="inv-stat-sub">4 invoice overdue</div></div>
  </div>

  <div class="inv-filter-bar">
    <div class="inv-search">
      <i class='bx bx-search'></i>
      <input type="text" placeholder="Cari nomor invoice atau nama klien..." id="invSearch" oninput="filterInvoices()" />
    </div>
    <div class="inv-status-tabs">
      <button class="inv-status-tab active" onclick="filterByStatus('', this)">Semua</button>
      <button class="inv-status-tab" onclick="filterByStatus('paid', this)">Terbayar</button>
      <button class="inv-status-tab" onclick="filterByStatus('pending', this)">Tertunda</button>
      <button class="inv-status-tab" onclick="filterByStatus('overdue', this)">Jatuh Tempo</button>
    </div>
    <select class="filter-select" id="invSort" onchange="filterInvoices()">
      <option value="">Urutkan: Terbaru</option>
      <option value="oldest">Terlama</option>
      <option value="highest">Nominal Tertinggi</option>
      <option value="lowest">Nominal Terendah</option>
    </select>
  </div>

  <div class="table-wrapper">
    <table class="data-table" id="invTable">
      <thead>
        <tr>
          <th>No. Invoice</th><th>Nama Klien</th><th>Proyek</th><th>Tanggal</th>
          <th>Due Date</th><th>Nominal</th><th>Status</th><th>Aksi</th>
        </tr>
      </thead>
      <tbody id="invTableBody"></tbody>
    </table>
  </div>

  <div style="display:flex;align-items:center;justify-content:space-between;padding:16px 24px;border-top:1px solid var(--border)">
    <span style="font-size:13px;color:var(--text-secondary)">Menampilkan <strong id="invCount">10</strong> dari <strong>47</strong> invoice</span>
    <div style="display:flex;gap:6px">
      <button class="btn btn-outline btn-sm"><i class='bx bx-chevron-left'></i></button>
      <button class="btn btn-primary btn-sm">1</button>
      <button class="btn btn-outline btn-sm">2</button>
      <button class="btn btn-outline btn-sm">3</button>
      <button class="btn btn-outline btn-sm"><i class='bx bx-chevron-right'></i></button>
    </div>
  </div>
</div>

@section Scripts {
<script>
  const INVOICES = [
    { id:'INV-2026-047', client:'PT Maju Bersama',       project:'HR Management System',     date:'15 Apr 2026', due:'30 Apr 2026', amount:'Rp 45.000.000', status:'pending'  },
    { id:'INV-2026-046', client:'Toko Berkah Online',    project:'E-Commerce Portal',         date:'10 Apr 2026', due:'25 Apr 2026', amount:'Rp 32.500.000', status:'pending'  },
    { id:'INV-2026-045', client:'CV Logistik Nusantara', project:'Inventory & Stock System',  date:'05 Apr 2026', due:'20 Apr 2026', amount:'Rp 58.000.000', status:'paid'     },
    { id:'INV-2026-044', client:'Startup FinUp',         project:'Payment Gateway API',       date:'01 Apr 2026', due:'16 Apr 2026', amount:'Rp 28.000.000', status:'overdue'  },
    { id:'INV-2026-043', client:'PT Sukses Mandiri',     project:'Sales Analytics Dashboard', date:'28 Mar 2026', due:'12 Apr 2026', amount:'Rp 40.000.000', status:'overdue'  },
    { id:'INV-2026-042', client:'Koperasi Sejahtera',    project:'Approval Workflow System',  date:'25 Mar 2026', due:'09 Apr 2026', amount:'Rp 35.000.000', status:'paid'     },
    { id:'INV-2026-041', client:'PT Maju Bersama',       project:'HR System – Phase 1',       date:'20 Mar 2026', due:'04 Apr 2026', amount:'Rp 50.000.000', status:'paid'     },
    { id:'INV-2026-040', client:'Toko Berkah Online',    project:'E-Commerce Portal – DP',    date:'15 Mar 2026', due:'30 Mar 2026', amount:'Rp 25.000.000', status:'paid'     },
    { id:'INV-2026-039', client:'PT Bangun Karya',       project:'Custom CMS Website',        date:'10 Mar 2026', due:'25 Mar 2026', amount:'Rp 18.000.000', status:'overdue'  },
    { id:'INV-2026-038', client:'CV Digital Kreatif',    project:'Company Profile Website',   date:'05 Mar 2026', due:'20 Mar 2026', amount:'Rp 12.000.000', status:'paid'     },
  ];

  const detailUrl = '@Url.Action("Detail", "Invoices")';

  const BADGE = {
    paid:    '<span class="status-badge completed">Terbayar</span>',
    pending: '<span class="status-badge in-progress">Tertunda</span>',
    overdue: '<span class="status-badge" style="background:rgba(244,106,106,.12);color:var(--danger)">Jatuh Tempo</span>',
  };

  let currentFilter = '';

  function renderTable(data) {
    const tbody = document.getElementById('invTableBody');
    tbody.innerHTML = data.map(inv => `
      <tr>
        <td><strong style="color:var(--primary)">${inv.id}</strong></td>
        <td>
          <div style="display:flex;align-items:center;gap:10px">
            <div style="width:32px;height:32px;border-radius:8px;background:linear-gradient(135deg,var(--primary),#8B5CF6);color:#fff;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0">${inv.client.charAt(0)}</div>
            <span style="font-weight:500">${inv.client}</span>
          </div>
        </td>
        <td style="color:var(--text-secondary);font-size:12.5px">${inv.project}</td>
        <td>${inv.date}</td>
        <td>${inv.due}</td>
        <td><strong>${inv.amount}</strong></td>
        <td>${BADGE[inv.status]}</td>
        <td>
          <div style="display:flex;gap:6px">
            <a href="${detailUrl}" class="btn btn-outline btn-sm btn-icon" title="Lihat Detail"><i class='bx bx-show'></i></a>
            <button class="btn btn-outline btn-sm btn-icon" title="Download PDF"><i class='bx bx-download'></i></button>
            <button class="btn btn-outline btn-sm btn-icon" onclick="deleteRow(this)" title="Hapus"><i class='bx bx-trash' style="color:var(--danger)"></i></button>
          </div>
        </td>
      </tr>`).join('');
    document.getElementById('invCount').textContent = data.length;
  }

  function filterInvoices() {
    const q = document.getElementById('invSearch').value.toLowerCase();
    const filtered = INVOICES.filter(inv =>
      (!currentFilter || inv.status === currentFilter) &&
      (!q || inv.id.toLowerCase().includes(q) || inv.client.toLowerCase().includes(q) || inv.project.toLowerCase().includes(q))
    );
    renderTable(filtered);
  }

  function filterByStatus(status, btn) {
    document.querySelectorAll('.inv-status-tab').forEach(b => b.classList.remove('active'));
    btn.classList.add('active'); currentFilter = status; filterInvoices();
  }

  function deleteRow(btn) { if (confirm('Hapus invoice ini?')) btn.closest('tr').remove(); }

  renderTable(INVOICES);
</script>
}
