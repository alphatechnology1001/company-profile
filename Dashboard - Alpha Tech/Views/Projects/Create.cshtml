@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Buat Proyek Baru";
}

<div class="page-header">
  <div>
    <h1 class="page-title">Buat Proyek Baru</h1>
    <p class="page-subtitle">Isi informasi proyek baru untuk mulai dikerjakan tim Alpha Technology</p>
  </div>
  <div class="page-header-actions">
    <a asp-controller="Projects" asp-action="Index" class="btn btn-outline"><i class='bx bx-arrow-back'></i> Kembali</a>
  </div>
</div>

<form onsubmit="submitProject(event)">
  <div class="create-proj-grid">

    <div style="display:flex;flex-direction:column;gap:20px">

      <div class="card" style="padding:24px">
        <h6 style="font-size:15px;font-weight:700;margin-bottom:18px;padding-bottom:12px;border-bottom:1px solid var(--border)">
          <i class='bx bx-info-circle' style="color:var(--primary);margin-right:6px"></i>Informasi Dasar
        </h6>
        <div class="form-group">
          <label class="form-label">Nama Proyek *</label>
          <input type="text" class="form-control" placeholder="cth: HR Management System" required />
        </div>
        <div class="form-group">
          <label class="form-label">Deskripsi Proyek</label>
          <textarea class="form-control" rows="4" placeholder="Jelaskan scope dan tujuan proyek secara singkat..."></textarea>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Klien *</label>
            <select class="form-control" required>
              <option value="">-- Pilih Klien --</option>
              <option>PT Maju Bersama</option>
              <option>Toko Berkah Online</option>
              <option>CV Logistik Nusantara</option>
              <option>Startup FinUp</option>
              <option>PT Sukses Mandiri</option>
              <option>Koperasi Sejahtera</option>
              <option>+ Klien Baru...</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Jenis Layanan *</label>
            <select class="form-control" required>
              <option value="">-- Pilih Layanan --</option>
              <option>Custom Web Application</option>
              <option>Sistem Internal (HR/Inventory/Approval)</option>
              <option>API Integration</option>
              <option>Data &amp; Reporting System</option>
            </select>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Tanggal Mulai *</label>
            <input type="date" class="form-control" required />
          </div>
          <div class="form-group">
            <label class="form-label">Deadline *</label>
            <input type="date" class="form-control" required />
          </div>
        </div>
      </div>

      <div class="card" style="padding:24px">
        <h6 style="font-size:15px;font-weight:700;margin-bottom:18px;padding-bottom:12px;border-bottom:1px solid var(--border)">
          <i class='bx bx-money' style="color:var(--success);margin-right:6px"></i>Informasi Keuangan
        </h6>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Nilai Kontrak (Rp) *</label>
            <input type="number" class="form-control" placeholder="cth: 45000000" required />
          </div>
          <div class="form-group">
            <label class="form-label">Down Payment (DP)</label>
            <input type="number" class="form-control" placeholder="cth: 22500000" />
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Metode Pembayaran</label>
            <select class="form-control">
              <option>Transfer Bank (BCA)</option>
              <option>Transfer Bank (Mandiri)</option>
              <option>Tunai</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Termin Pembayaran</label>
            <select class="form-control">
              <option>50% DP, 50% Selesai</option>
              <option>30% DP, 40% Milestone, 30% Selesai</option>
              <option>Lunas di Awal</option>
              <option>Monthly Retainer</option>
            </select>
          </div>
        </div>
      </div>

      <div class="card" style="padding:24px">
        <h6 style="font-size:15px;font-weight:700;margin-bottom:18px;padding-bottom:12px;border-bottom:1px solid var(--border)">
          <i class='bx bx-code-block' style="color:var(--info);margin-right:6px"></i>Tech Stack &amp; Arsitektur
        </h6>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Backend</label>
            <select class="form-control">
              <option>.NET Framework / .NET Core</option>
              <option>Node.js</option>
              <option>PHP Laravel</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Database</label>
            <select class="form-control">
              <option>Microsoft SQL Server</option>
              <option>MySQL / MariaDB</option>
              <option>PostgreSQL</option>
            </select>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Frontend Framework</label>
            <select class="form-control">
              <option>Razor Pages (.NET MVC)</option>
              <option>React.js</option>
              <option>Vue.js</option>
              <option>Vanilla HTML/CSS/JS</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Arsitektur</label>
            <select class="form-control">
              <option>Monolithic (Recommended)</option>
              <option>Microservices</option>
              <option>Serverless</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Catatan Teknis Tambahan</label>
          <textarea class="form-control" rows="2" placeholder="cth: Butuh integrasi dengan sistem lama berbasis VBA Excel..."></textarea>
        </div>
      </div>

    </div>

    <div class="create-task-sidebar">

      <div class="card" style="padding:20px">
        <h6 style="font-size:13px;font-weight:700;margin-bottom:14px">Status &amp; Prioritas</h6>
        <div class="form-group">
          <label class="form-label">Status Awal</label>
          <select class="form-control">
            <option>Planning</option>
            <option>In Progress</option>
            <option>On Hold</option>
          </select>
        </div>
        <div class="form-group" style="margin-bottom:0">
          <label class="form-label">Prioritas</label>
          <div class="priority-cards">
            <div class="priority-card selected high" onclick="selectPriority(this)">
              <div class="priority-card-icon">🔴</div>
              <div class="priority-card-label" style="color:var(--danger)">Tinggi</div>
            </div>
            <div class="priority-card medium" onclick="selectPriority(this)">
              <div class="priority-card-icon">🟡</div>
              <div class="priority-card-label" style="color:#b7801a">Sedang</div>
            </div>
            <div class="priority-card low" onclick="selectPriority(this)">
              <div class="priority-card-icon">🟢</div>
              <div class="priority-card-label" style="color:var(--success)">Rendah</div>
            </div>
          </div>
        </div>
      </div>

      <div class="card" style="padding:20px">
        <h6 style="font-size:13px;font-weight:700;margin-bottom:14px">Assign Tim</h6>
        <div class="assignee-select-list">
          <div class="assignee-row">
            <input type="checkbox" checked id="dev1" />
            <div style="width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--primary),#8B5CF6);color:#fff;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700">RY</div>
            <div style="flex:1">
              <div class="assignee-row-name">Ryan Yudistira</div>
              <div class="assignee-row-role">Lead Developer</div>
            </div>
          </div>
          <div class="assignee-row">
            <input type="checkbox" checked id="dev2" />
            <div style="width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--success),#0dcb8c);color:#fff;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700">AD</div>
            <div style="flex:1">
              <div class="assignee-row-name">Andi Developer</div>
              <div class="assignee-row-role">Backend Developer</div>
            </div>
          </div>
        </div>
      </div>

      <div class="card" style="padding:20px">
        <h6 style="font-size:13px;font-weight:700;margin-bottom:14px">Tags / Label</h6>
        <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:10px" id="tagList">
          <span class="tag tag-primary" onclick="removeTag(this)" style="cursor:pointer">.NET ×</span>
          <span class="tag tag-success" onclick="removeTag(this)" style="cursor:pointer">SQL Server ×</span>
          <span class="tag tag-info"    onclick="removeTag(this)" style="cursor:pointer">HR System ×</span>
        </div>
        <div style="display:flex;gap:8px">
          <input type="text" id="tagInput" class="form-control" placeholder="Tambah tag..." style="flex:1"
                 onkeydown="if(event.key==='Enter'){event.preventDefault();addTag()}" />
          <button type="button" class="btn btn-outline btn-sm" onclick="addTag()"><i class='bx bx-plus'></i></button>
        </div>
      </div>

      <div style="display:flex;flex-direction:column;gap:10px">
        <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:12px">
          <i class='bx bx-rocket'></i> Buat Proyek
        </button>
        <a asp-controller="Projects" asp-action="Index" class="btn btn-outline" style="width:100%;justify-content:center;">Batal</a>
      </div>

    </div>
  </div>
</form>

@section Scripts {
<script>
  const projectsUrl = '@Url.Action("Index", "Projects")';

  function selectPriority(el) {
    document.querySelectorAll('.priority-card').forEach(c => c.classList.remove('selected'));
    el.classList.add('selected');
  }

  function addTag() {
    const input = document.getElementById('tagInput');
    const val = input.value.trim();
    if (!val) return;
    const tagList = document.getElementById('tagList');
    const colors = ['tag-primary','tag-success','tag-warning','tag-info','tag-danger'];
    const color  = colors[tagList.children.length % colors.length];
    const span = document.createElement('span');
    span.className = `tag ${color}`;
    span.style.cursor = 'pointer';
    span.textContent = val + ' ×';
    span.onclick = () => removeTag(span);
    tagList.appendChild(span);
    input.value = '';
  }

  function removeTag(el) { el.remove(); }

  function submitProject(e) {
    e.preventDefault();
    const btn = e.submitter || document.querySelector('[type=submit]');
    const orig = btn.innerHTML;
    btn.innerHTML = '<i class="bx bx-loader-alt bx-spin"></i> Membuat proyek...';
    btn.disabled = true;
    setTimeout(() => { window.location.href = projectsUrl; }, 1500);
  }
</script>
}
